###################
*.com
*.class
*.dll
*.exe
*.o
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Anchored to repo root — unanchored `.meta` also matched template/.meta and
# got dropped from copier's dirty-tree wip commit (empty-index clone + add -A).
/.meta
/todo.md
# Re-include the template's .meta — global gitignores often ignore `.meta`
# unanchored, which silently drops these files from copier's dirty-tree wip
# commit (clone --no-checkout has an empty index, so ignore rules apply even
# to tracked files during its `git add -A`).
!template/.meta/
!template/.meta/**
*.code-workspace
.copier-answers.yml
.copier-answers.yml.backup

# tool caches
.task/
.worktrees/
.lefthook-local.yml

# Local editor/AI settings
settings.local.json

# Devcontainer env files (injected locally via 1Password, never committed)
.devcontainer/**/devcontainer.env

#             .env
#------------------------------------------------------------------------------
# Ignore all .env files
.env
# Ignore all .env files in any subdirectory
**/.env
# Ignore all .env.* files (e.g., .env.local, .env.production)
.env.*
# Ignore all .env.* files in any subdirectory
**/.env.*
# Ignore any directory named .env
.env/
