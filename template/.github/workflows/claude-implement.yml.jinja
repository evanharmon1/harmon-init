name: Claude Implement
run-name: ${{ github.actor }} is running Claude Implement
# Requires repo secrets: CLAUDE_CODE_OAUTH_TOKEN, GH_WORKFLOW_PAT (see docs/CHECKLIST.md)
on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
  pull_request_review:
    types: [submitted]
  issues:
    types: [opened, assigned, labeled]
jobs:
  implement:
    if: >-
      (github.event.sender.login == '[[ author_git_provider_username ]]' ||
       github.event.sender.login == '[[ author_git_provider_username ]]-bot') &&
      (contains(github.event.comment.body, '@claude implement') ||
       contains(github.event.review.body, '@claude implement') ||
       contains(github.event.issue.body, '@claude implement') ||
       (github.event.action == 'labeled' &&
        github.event.label.name == 'claude-implement'))
    runs-on: [ [[ ci_runner_labels ]] ]
    permissions:
      contents: write
      issues: write
      pull-requests: write
      id-token: write
    steps:
      - uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10 # v6.0.3
        with:
          fetch-depth: 0
          token: ${{ secrets.GH_WORKFLOW_PAT }}
      - name: Configure git identity as [[ author_git_provider_username ]]-bot
        run: |
          git config --global user.name "[[ author_git_provider_username ]]-bot"
          git config --global user.email "[[ author_git_provider_username ]]-bot@users.noreply.github.com"
[% if github_org != author_git_provider_username %]
      - name: Set issue status to In Progress
        continue-on-error: true
        env:
          GH_TOKEN: ${{ secrets.GH_WORKFLOW_PAT }}
          ISSUE_NUMBER: ${{ github.event.issue.number }}
        run: |
          [ -z "$ISSUE_NUMBER" ] && echo "No issue number, skipping" && exit 0

          PROJECT_ID=$(gh api graphql -f query='
            query($o:String!,$n:Int!){organization(login:$o){projectV2(number:$n){id}}}
            ' -f o=[[ github_org ]] -F n=1 --jq '.data.organization.projectV2.id')

          ITEM_ID=""
          CURSOR=""
          while true; do
            PAGE=$(gh api graphql -f query='
              query($i:ID!,$after:String){node(id:$i){...on ProjectV2{items(first:100,after:$after){pageInfo{hasNextPage endCursor} nodes{id content{...on Issue{number}}}}}}}
              ' -F i="$PROJECT_ID" ${CURSOR:+-F after="$CURSOR"} 2>/dev/null || true)
            ITEM_ID=$(echo "$PAGE" | jq -r ".data.node.items.nodes[]|select(.content.number?==$ISSUE_NUMBER)|.id" 2>/dev/null || true)
            [ -n "$ITEM_ID" ] && break
            HAS_NEXT=$(echo "$PAGE" | jq -r '.data.node.items.pageInfo.hasNextPage')
            [ "$HAS_NEXT" != "true" ] && break
            CURSOR=$(echo "$PAGE" | jq -r '.data.node.items.pageInfo.endCursor')
          done

          [ -z "$ITEM_ID" ] && echo "Issue #$ISSUE_NUMBER not in project, skipping" && exit 0

          STATUS_DATA=$(gh api graphql -f query='
            query($i:ID!){node(id:$i){...on ProjectV2{fields(first:20){nodes{...on ProjectV2SingleSelectField{id name options{id name}}}}}}}
            ' -F i="$PROJECT_ID")

          FIELD_ID=$(echo "$STATUS_DATA" | jq -r '.data.node.fields.nodes[]|select(.name=="Status")|.id')
          OPTION_ID=$(echo "$STATUS_DATA" | jq -r '.data.node.fields.nodes[]|select(.name=="Status")|.options[]|select(.name=="In Progress")|.id')

          [ -z "$OPTION_ID" ] && echo "Status option 'In Progress' not found, skipping" && exit 0

          gh api graphql -f query='
            mutation($p:ID!,$i:ID!,$f:ID!,$v:String!){
              updateProjectV2ItemFieldValue(input:{projectId:$p,itemId:$i,fieldId:$f,value:{singleSelectOptionId:$v}}){projectV2Item{id}}
            }' -F p="$PROJECT_ID" -F i="$ITEM_ID" -F f="$FIELD_ID" -F v="$OPTION_ID"
          echo "Set issue #$ISSUE_NUMBER to In Progress"
[% endif %]
      - uses: anthropics/claude-code-action@fbda2eb1bdc90d319b8d853f5deb53bca199a7c1 # v1.0.140
        with:
          claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
          github_token: ${{ secrets.GH_WORKFLOW_PAT }}
          trigger_phrase: "@claude implement"
          label_trigger: "claude-implement"
          track_progress: true
          base_branch: main
          branch_prefix: claude/
          branch_name_template: "{{prefix}}issue-{{entityNumber}}-{{description}}-{{sha}}"
          claude_args: "--model sonnet --max-turns 200"
          prompt: |
            Implement the change requested in this issue or comment.

            Operating rules (non-negotiable):
            - Do NOT ask clarifying questions. Pick the most reasonable
              interpretation of the request and proceed. State any non-obvious
              assumptions in the PR body so the reviewer can redirect if needed.
            - The only acceptable terminal states are:
                (a) an opened pull request on a claude/... branch, or
                (b) an opened DRAFT pull request that documents what blocked you.
              Do NOT end by leaving a summary comment on the issue — the PR is
              the deliverable, not the comment.
            - If `task verify` fails and you cannot resolve it within several
              attempts, commit the best-effort state, push the branch, open a
              DRAFT PR, and describe the failing step in the PR body. Do not
              abandon the branch or dump a diff in a comment.

            Workflow:
            1. Make the code changes directly in the working tree.
            2. Run `task verify` and fix any failures before continuing.
            3. Commit with a conventional-commits message referencing this issue.
            4. Push the branch to origin.
            5. Open a pull request targeting main. In the PR body, link to this
               issue with "Closes #${{ github.event.issue.number || github.event.pull_request.number }}", summarize
               what changed, and note anything reviewers should pay attention to.

            Do not post the diff as a comment. The PR is the deliverable.

            Follow the conventions documented in AGENTS.md, including the
            commit-message style.
