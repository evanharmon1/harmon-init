# Brewfile for [[ project_name ]]
# Install with: task install  (brew bundle --file=Brewfile)

# Task runner + git hooks
brew "go-task"
brew "lefthook"

# Git / GitHub
brew "git"
brew "gh"

# Lint / format
brew "shellcheck"
brew "shfmt"
brew "actionlint"
brew "yamllint"

# Security
brew "gitleaks"
tap "snyk/tap"
brew "snyk/tap/snyk"

# Runtime for npx-based tools (commitlint, markdownlint-cli2)
brew "node"
[% if use_node %]
brew "pnpm"
brew "lychee"
[% endif %]
[% if use_python %]

# Python tooling
brew "uv"
[% endif %]
[% if include_terraform %]

# Terraform
brew "terraform"
[% endif %]
[% if devcontainer %]

# Devcontainer
brew "hadolint"
[% endif %]

# Utilities
brew "jq"
brew "fzf"
brew "fd"
brew "ripgrep"
brew "bat"
[% if bunch_add %]

# macOS apps
cask "bunch"
[% endif %]
