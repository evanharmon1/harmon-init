---
extends: default

# template/ contains jinja-templated YAML (and jinja-named paths) that is not
# valid YAML until rendered; the rendered output is linted by test:template:*.
ignore:
  - template/
  - node_modules/
  - .task/
  - .worktrees/

rules:
  braces:
    level: warning
    max-spaces-inside: 1
  brackets:
    level: warning
    max-spaces-inside: 1
  colons:
    level: warning
  commas:
    level: warning
  comments: disable
  comments-indentation: disable
  document-start: disable
  empty-lines:
    level: warning
  hyphens:
    level: warning
  indentation:
    level: warning
    indent-sequences: consistent
  line-length:
    max: 200
    level: warning
    allow-non-breakable-inline-mappings: true
  truthy: disable
